# Copy this file to .env and fill in your values.
# Get your Client ID from https://developer.spotify.com/dashboard

# Your Spotify app's Client ID
VITE_SPOTIFY_CLIENT_ID=your_client_id_here

# OAuth redirect URI — must match EXACTLY what's registered in your Spotify app dashboard.
# Note: Spotify's dashboard requires HTTPS. For local dev, use a tunnel (e.g. localtunnel):
#   npx localtunnel --port 5174 --subdomain your-name-dev
#   VITE_REDIRECT_URI=https://your-name-dev.loca.lt/callback
# Production (replace with your actual deployed URL):
#   VITE_REDIRECT_URI=https://your-site.netlify.app/callback
VITE_REDIRECT_URI=https://your-site.netlify.app/callback
